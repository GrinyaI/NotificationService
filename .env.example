APP_PORT=8080

DB_PORT=5432
DB_NAME=notifications_database
DB_USER=postgres
DB_PASS=postgres

KAFKA_EXTERNAL_PORT=9092
REDIS_PORT=6379

JAVA_OPTS=-XX:MaxRAMPercentage=75.0

# SMS provider: SIMULATED or EXOLVE.
SMS_PROVIDER=SIMULATED

# MTS Exolve integration.
EXOLVE_API_KEY=
EXOLVE_BASE_URL=https://api.exolve.ru
EXOLVE_SENDER_NUMBER=

# Email provider: SIMULATED or YANDEX_SMTP.
EMAIL_PROVIDER=SIMULATED

# Yandex SMTP integration. Use an application password, not the account password.
YANDEX_SMTP_HOST=smtp.yandex.ru
YANDEX_SMTP_PORT=465
YANDEX_SMTP_USERNAME=
YANDEX_SMTP_PASSWORD=
YANDEX_SMTP_FROM=
YANDEX_SMTP_SUBJECT=NotificationService notification
YANDEX_SMTP_SSL_ENABLED=true
YANDEX_SMTP_STARTTLS_ENABLED=false

# Uncomment to override the default daily 03:00 archive schedule.
# NOTIFICATION_ARCHIVE_CRON=0 0 3 * * ?
NOTIFICATION_ARCHIVE_RETENTION_DAYS=30
